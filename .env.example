# Yn Security Bot - Environment Variables Example
# Copy this file to .env and fill in your actual values

# Bot token from Bot Father
BOT_TOKEN=your_bot_token_here

# Telegram API ID and API Hash from https://my.telegram.org/apps
API_ID=12345678
API_HASH=your_api_hash_here

# Log chat ID (optional, use your channel/group ID)
LOG_CHAT=-1001234567890

# Number of workers (default: 24)
WORKERS=24
